#RTL-SDR
# apt-get install rtl-sdr
# install udev
# sudo wget -P /etc/udev/rules.d https://raw.githubusercontent.com/osmocom/rtl-sdr/master/rtl-sdr.rules
# for v4, you need to manually install drivers
# to find gain values, run rtl_test
rtl_fm -M wbfm -f 94.5M -r 22500 | play -r 22500 -t raw -e s -b 16 -c 1 -v 0.1 -
rtl_fm -f 144.390M -s 22050 -g 40 - | multimon-ng -t raw -A -a AFSK1200 -
rtl_fm -f 144.390M -s 22050 -g 40 - | pypy3 aprs_demod.py -t u16 -
rtl_fm -f 144.390M -s 22050 -g 40 - | sox -t raw -b 16 -e signed-integer -c 1 -v 1 -r 22050 -  -t wav test/ttwr.wav
sox -t wav test/ttwr.wav -t raw -b 16 -e signed-integer -c 1 -r 22050 - | python aprs_demod.py -t -
rtl_fm -f 144.390M -s 22050 -g 40 - | sox -t raw -b 16 -e signed-integer -c 1 -v 1 -r 22050 -  -t wav static.wav

#STATIC
sox -t wav test/static.wav -t raw -b 16 -e signed-integer -c 1 -r 22050 - | python squelch_test.py

#APRS IS
