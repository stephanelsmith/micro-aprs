rtl_fm -f 144.390M -s 22050 -g 40 - | pypy3 aprs_demod.py -t - | python aprs_is.py -c KW5O-10 -lat 29.70943374654428 -lon -95.8243956738793
rtl_fm -f 144.390M -s 22050 -g 30 - | micropython aprs_demod.py -t - | python aprs_is.py -c KW5O-10 -lat 29.70943374654428 -lon -95.8243956738793
python aprs_demod.py -t rtl_fm | python aprs_is.py -c KW5O-10 -lat 29.70943374654428 -lon -95.8243956738793


